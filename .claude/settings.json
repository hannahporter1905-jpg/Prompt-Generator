{
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(npm run dev *)",
      "Bash(npm run build *)",
      "Bash(node scripts/*)",
      "Bash(ls *)",
      "Bash(mkdir *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "git add -A && git commit -m \"auto: Claude edit\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
